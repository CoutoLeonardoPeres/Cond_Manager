{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Cond Manager (Web)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "deviceId": "chrome",
      "toolArgs": [
        "--dart-define-from-file=dart_defines.json"
      ]
    },
    {
      "name": "Cond Manager (Safari)",
      "request": "launch",
