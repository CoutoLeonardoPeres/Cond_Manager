  "replicationGuide": {
    "steps": [
      "1. Clone repository or copy lib/, supabase/, pubspec.yaml, assets/",
      "2. Create Supabase project; run docs/cond_manager_database_full.sql OR migrations in order",
      "3. cp dart_defines.example.json dart_defines.json (or cp .env.example .env) and set SUPABASE_URL + SUPABASE_ANON_KEY",
      "4. Run supabase/fix_admin_profile.sql after first user signup",
      "5. flutter pub get && flutter run -d chrome --dart-define-from-file=dart_defines.json",
      "6. Enable modules per company in admin/modules",
      "7. Optional seeds: seed_optional.sql, seed_rental_module.sql"
    ],
    "devNotes": [
      "Disable email confirm in Supabase Auth for local dev",
      "Platform admin: UPDATE profiles SET is_platform_admin = true",
      "Two AppModules require company_modules table entries",
      "iOS: Runner Release scheme + Runner-Debug for LLDB; use flutterMode release in launch.json",
      "Never commit dart_defines.json or .env"
    ]
  }
